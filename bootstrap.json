{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "ProdPRONOMInfrastructureRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "ProdPRONOMInfrastructureRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Federated": {
                  "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                }
              },
              "Action": "sts:AssumeRoleWithWebIdentity",
              "Condition": {
                "StringLike": {
                  "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
                  "token.actions.githubusercontent.com:sub": [
                    "repo:nationalarchives/pronom-website:environment:production"
                  ]
                }
              }
            },
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:root"
                }
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "ProdPRONOMInfrastructurePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "",
                  "Effect": "Allow",
                  "Action": [
                    "acm:*",
                    "apigateway:*",
                    "cloudformation:*",
                    "cloudfront:*",
                    "cloudwatch:*",
                    "events:*",
                    "lambda:*",
                    "logs:*",
                    "route53:*",
                    "s3:*",
                    "scheduler:*",
                    "secretsmanager:*",
                    "shield:*",
                    "ssm:GetParameter",
                    "wafv2:*"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "",
                  "Effect": "Allow",
                  "Action": [
                    "iam:AttachRolePolicy",
                    "iam:CreatePolicy",
                    "iam:CreateRole",
                    "iam:DeletePolicy",
                    "iam:DeleteRole",
                    "iam:DetachRolePolicy",
                    "iam:DeleteRolePolicy",
                    "iam:GetOpenIDConnectProvider",
                    "iam:GetPolicy",
                    "iam:GetPolicyVersion",
                    "iam:GetRole",
                    "iam:GetRolePolicy",
                    "iam:ListPolicyVersions",
                    "iam:ListRolePolicies",
                    "iam:ListAttachedRolePolicies",
                    "iam:ListInstanceProfilesForRole",
                    "iam:PassRole",
                    "iam:PutRolePolicy",
                    "iam:TagPolicy",
                    "iam:TagRole",
                    "iam:UntagRole",
                    "iam:UpdateRoleDescription",
                    "iam:UpdateAssumeRolePolicy"
                  ],
                  "Resource": [
                    "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:role/prod-*"
                    },
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:policy/prod-*"
                    },
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                    }
                  ]
                },
                {
                  "Sid": "DenyInvokeFunction",
                  "Effect": "Deny",
                  "Action": ["lambda:Invoke*"],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      }
    },
    "TestPRONOMInfrastructureRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "TestPRONOMInfrastructureRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Federated": {
                  "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                }
              },
              "Action": "sts:AssumeRoleWithWebIdentity",
              "Condition": {
                "StringLike": {
                  "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
                  "token.actions.githubusercontent.com:sub": [
                    "repo:nationalarchives/pronom-website:environment:test"
                  ]
                }
              }
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "TestPRONOMInfrastructurePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "",
                  "Effect": "Allow",
                  "Action": [
                    "route53:*",
                    "acm:*",
                    "cloudfront:*",
                    "cloudformation:*",
                    "cloudwatch:*",
                    "events:*",
                    "apigateway:*",
                    "logs:*",
                    "lambda:*",
                    "scheduler:*",
                    "shield:*",
                    "wafv2:*",
                    "s3:*",
                    "ssm:GetParameter"
                  ],
                  "Resource": "*"
                },
                {
                  "Sid": "",
                  "Effect": "Allow",
                  "Action": [
                    "iam:AttachRolePolicy",
                    "iam:CreatePolicy",
                    "iam:CreateRole",
                    "iam:DeletePolicy",
                    "iam:DeleteRole",
                    "iam:DetachRolePolicy",
                    "iam:DeleteRolePolicy",
                    "iam:GetOpenIDConnectProvider",
                    "iam:GetPolicy",
                    "iam:GetPolicyVersion",
                    "iam:GetRole",
                    "iam:GetRolePolicy",
                    "iam:ListPolicyVersions",
                    "iam:ListRolePolicies",
                    "iam:ListAttachedRolePolicies",
                    "iam:ListInstanceProfilesForRole",
                    "iam:PassRole",
                    "iam:PutRolePolicy",
                    "iam:TagPolicy",
                    "iam:TagRole",
                    "iam:UntagRole",
                    "iam:UpdateRoleDescription",
                    "iam:UpdateAssumeRolePolicy"
                  ],
                  "Resource": [
                    "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole",
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:role/test-*"
                    },
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:policy/test-*"
                    },
                    {
                      "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                    }
                  ]
                },
                {
                  "Sid": "DenyInvokeFunction",
                  "Effect": "Deny",
                  "Action": ["lambda:Invoke*"],
                  "Resource": "*"
                }
              ]
            }
          }
        ]
      }
    },
    "PRONOMDeploySignatureRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "PRONOMSignatureRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Federated": {
                  "Fn::Sub": "arn:aws:iam::${AWS::AccountId}:oidc-provider/token.actions.githubusercontent.com"
                }
              },
              "Action": "sts:AssumeRoleWithWebIdentity",
              "Condition": {
                "StringLike": {
                  "token.actions.githubusercontent.com:aud": "sts.amazonaws.com",
                  "token.actions.githubusercontent.com:sub": [
                    "repo:nationalarchives/pronom-signatures:environment:prod"
                  ]
                }
              }
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "PRONOMSignaturePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Sid": "",
                  "Effect": "Allow",
                  "Action": ["s3:PutObject", "s3:ListBucket"],
                  "Resource": [
                    {
                      "Fn::Sub": "arn:aws:s3:::prod-pronom-site-${AWS::AccountId}-eu-west-2-an"
                    },
                    {
                      "Fn::Sub": "arn:aws:s3:::prod-pronom-site-${AWS::AccountId}-eu-west-2-an/*"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "ProdPronomSiteTerraformStateBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "prod-pronom-site-terraform-state",
        "OwnershipControls": {
          "Rules": [
            {
              "ObjectOwnership": "BucketOwnerEnforced"
            }
          ]
        },
        "PublicAccessBlockConfiguration": {
          "BlockPublicAcls": true,
          "IgnorePublicAcls": true,
          "BlockPublicPolicy": true,
          "RestrictPublicBuckets": true
        },
        "BucketEncryption": {
          "ServerSideEncryptionConfiguration": [
            {
              "ServerSideEncryptionByDefault": {
                "SSEAlgorithm": "AES256"
              }
            }
          ]
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      }
    },
    "ProdPronomSiteTerraformStateBucketPolicy": {
      "Type": "AWS::S3::BucketPolicy",
      "Properties": {
        "Bucket": {
          "Ref": "ProdPronomSiteTerraformStateBucket"
        },
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "DenyInsecureTransport",
              "Effect": "Deny",
              "Principal": "*",
              "Action": "s3:*",
              "Resource": [
                {
                  "Fn::Sub": "arn:${AWS::Partition}:s3:::prod-pronom-site-terraform-state"
                },
                {
                  "Fn::Sub": "arn:${AWS::Partition}:s3:::prod-pronom-site-terraform-state/*"
                }
              ],
              "Condition": {
                "Bool": {
                  "aws:SecureTransport": "false"
                }
              }
            }
          ]
        }
      }
    }
  }
}
